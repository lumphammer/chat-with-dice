---
import Layout from "#/layouts/Layout.astro";
import { StandaloneFileManager } from "@/components/FileManager/StandaloneFileManager";
import { env } from "cloudflare:workers";

export const prerender = false;

const user = Astro.locals.user;
if (!user) {
  return Astro.redirect("/signin");
}

const rawPath = Astro.params.path ?? "";
const pathSegments = rawPath.split("/").filter(Boolean).map(decodeURIComponent);

if (Astro.locals.user === null) {
  return Astro.redirect(
    `/signin?returnUrl=${encodeURIComponent(Astro.request.url)}`,
  );
}

if (Astro.locals.user.isAnonymous) {
  return Astro.redirect(
    `/signup?returnUrl=${encodeURIComponent(Astro.request.url)}`,
  );
}

let doIdString = Astro.locals.user.userDataDOId;

// we can probably drop this in due course - backfill the doId
if (!doIdString) {
  throw new Error("user_data_do_id is not set");
}

const userDataDO = env.USER_DATA_DO.get(
  env.USER_DATA_DO.idFromString(doIdString),
);

const resolution = await userDataDO.resolvePathToFolder(pathSegments);

if (resolution.kind === "not-found") {
  return new Response("Not found", { status: 404 });
}

const folderId = resolution.folderId;
const breadcrumbs = resolution.breadcrumbs;
let initialNodes: Awaited<ReturnType<typeof userDataDO.getNodes>>;

try {
  initialNodes = await userDataDO.getNodes(folderId ?? undefined, false);
} catch (e) {
  return new Response("Not found", { status: 404 });
}

// if the path resolved to a file, we need to find the file node in the list
// so the client can immediately open the preview
const previewFileId = resolution.kind === "file" ? resolution.fileNodeId : null;
const previewFileName =
  previewFileId === null
    ? null
    : (initialNodes.find((node) => node.id === previewFileId)?.name ?? null);
---

<Layout title="Files" class="flex justify-center">
  <StandaloneFileManager
    client:only="react"
    initialNodes={initialNodes}
    initialLocation={{
      folderId,
      breadcrumbs,
      previewFileId,
      previewFileName,
    }}
  />
</Layout>
