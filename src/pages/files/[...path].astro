---
import Layout from "#/layouts/Layout.astro";
import { FileManager } from "./_components/FileManager";
import { getUserNodes } from "./_components/queries";

export const prerender = false;

const user = Astro.locals.user;
if (!user) {
  return Astro.redirect("/signin");
}

// const path = Astro.params.path;
const rootNodes = await getUserNodes(user.id);
---

<Layout client:load title="Files" class="flex justify-center p-8">
  <FileManager initialNodes={rootNodes} />
</Layout>
