---
import Layout from "#/layouts/Layout.astro";
import { NewRoomFormWrapper } from "./_components/NewRoomForm";

export const prerender = false;

const session = Astro.locals.user;
const isLoggedIn = session !== null;
---

<Layout title="Create a Room" class="flex items-center justify-center p-6">
  <NewRoomFormWrapper client:load initialIsLoggedIn={isLoggedIn} />
</Layout>
