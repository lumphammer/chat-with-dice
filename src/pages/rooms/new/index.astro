---
import Layout from "#/layouts/Layout.astro";
import { NewRoomFormWrapper } from "./_components/NewRoomForm";

export const prerender = false;

if (!Astro.locals.user) {
  return Astro.redirect("/signin?returnUrl=/rooms/new");
}
---

<Layout title="Create a Room" class="flex items-center justify-center p-6">
  <NewRoomFormWrapper client:load />
</Layout>
