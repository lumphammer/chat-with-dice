---
import Logo from "#/assets/logo.svg";
import { NavBarAccount } from "#/components/NavBarAccount";
import HTML from "#/layouts/HTML.astro";
import "#/styles/global.css";
---

<HTML title="Chat with Dice">
  <!-- Nav -->
  <header class="navbar bg-base-100/80 fixed top-0 z-10 px-6 backdrop-blur-sm">
    <div class="navbar-start">
      <Logo
        width={36}
        height={36}
        aria-hidden="true"
        class="[&_.dark-part]:fill-[oklch(from_var(--color-neutral)_0.95_c_h)]
          [&_.die-pips]:fill-[oklch(from_var(--color-primary)_0.4_c_h)]
          [&_.light-part]:fill-[oklch(from_var(--color-neutral)_1_c_h)]
          [&_.stroke]:fill-none
          [&_.stroke]:stroke-[oklch(from_var(--color-neutral)_0.7_c_h)]
          [&_.stroke]:stroke-4"
      />
    </div>
    <div class="navbar-end gap-3">
      <NavBarAccount client:only initialUser={null} />
      <a href="/roller/new" class="btn btn-primary btn-sm">Create a room</a>
    </div>
  </header>

  <!-- Hero -->
  <main
    class="flex flex-1 flex-col items-center justify-center px-6 pt-24 pb-16
      text-center"
  >
    <div class="flex max-w-2xl flex-col items-center gap-8">
      <!-- Logo -->
      <div class="relative">
        <div class="bg-primary/20 absolute inset-0 -m-6 rounded-full blur-3xl">
        </div>
        <Logo
          width={120}
          height={120}
          aria-label="Chat with Dice"
          class="relative
            [&_.dark-part]:fill-[oklch(from_var(--color-neutral)_0.92_c_h)]
            [&_.die-pips]:fill-[oklch(from_var(--color-primary)_0.5_c_h)]
            [&_.light-part]:fill-[oklch(from_var(--color-neutral)_1_c_h)]
            [&_.stroke]:fill-none
            [&_.stroke]:stroke-[oklch(from_var(--color-neutral)_0.65_c_h)]
            [&_.stroke]:stroke-4"
        />
      </div>

      <!-- Heading -->
      <div class="flex flex-col gap-3">
        <h1
          class="text-primary text-5xl font-extrabold tracking-tight
            sm:text-6xl"
        >
          Chat with Dice
        </h1>
        <p class="text-base-content/70 text-lg sm:text-xl">
          Roll dice and chat with your party — in real time, in the same room,
          wherever you are.
        </p>
      </div>

      <!-- CTA -->
      <a href="/roller/new" class="btn btn-primary btn-lg gap-2 shadow-lg">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="22"
          height="22"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
          <path d="M16 8h.01M8 16h.01M12 12h.01"></path>
        </svg>
        Create a Room
      </a>

      <!-- Feature pills -->
      <div class="flex flex-wrap justify-center gap-3 text-sm">
        {
          [
            { icon: "🎲", label: "Shared dice rolling" },
            { icon: "💬", label: "Real-time chat" },
            { icon: "🔗", label: "Instant room sharing" },
          ].map(({ icon, label }) => (
            <span class="badge badge-outline badge-lg gap-1.5 px-4 py-3">
              <span aria-hidden="true">{icon}</span>
              {label}
            </span>
          ))
        }
      </div>
    </div>
  </main>

  <!-- Footer -->
  <footer class="text-base-content/40 pb-8 text-center text-sm">
    <p>
      Already have a room?{" "}
      <a href="/roller/rooms" class="link link-hover link-primary">
        Browse your rooms
      </a>
    </p>
  </footer>
</HTML>
