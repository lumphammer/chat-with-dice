---
import { db } from "#/db";
import Layout from "#/layouts/Layout.astro";
import { Rooms } from "#/schemas/chatDB-schema";
import { DiceRoller } from "@/components/DiceRoller/DiceRoller";
import { eq } from "drizzle-orm";

export const prerender = false;
const roomId = Astro.params["roomId"] ?? "";
const room = (
  await db.select().from(Rooms).where(eq(Rooms.id, roomId)).limit(1).all()
)[0];
if (!room) {
  return Astro.redirect("/roller");
}
---

<Layout title={room?.name ?? "(room not found)"}>
  <DiceRoller client:only roomId={roomId ?? ""} />
</Layout>
