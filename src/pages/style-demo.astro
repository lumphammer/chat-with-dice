---
import Layout from "#/layouts/HTML.astro";
---

<Layout title="Style Demo">
  {
    ["bg-base-100", "bg-base-200", "bg-base-300", "bg-black", "bg-white"].map(
      (bg) => {
        return (
          <div class={`m-6 p-6 ${bg} rounded`}>
            <h1 class="text-2xl font-bold">.{bg}</h1>
            <p>Some text</p>
            <p class="p text-primary">.text-primary</p>
            <p class="p text-secondary">.text-secondary</p>
            <p class="p text-accent">.text-accent</p>
            <p class="p text-primary-text">.text-primary-text</p>
            <p class="p text-secondary-text">.text-secondary-text</p>
            <p class="p text-accent-text">.text-accent-text</p>
            <div class="btn btn-primary">.btn-primary</div>
            <div class="btn btn-secondary">.btn-secondary</div>
            <div class="btn btn-accent">.btn-accent</div>
            <div class="btn btn-neutral">.btn-neutral</div>
            <div class="btn btn-soft btn-primary">.btn-soft.btn-primary</div>
            <div class="btn btn-soft btn-secondary">
              .btn-soft.btn-secondary
            </div>
            <div class="btn btn-soft btn-accent">.btn-soft.btn-accent</div>
            <div class="btn btn-soft btn-neutral">.btn-soft.btn-accent</div>
            <div class="btn btn-outline btn-primary">
              .btn-outline.btn-primary
            </div>
            <div class="btn btn-outline btn-secondary">
              .btn-outline.btn-secondary
            </div>
            <div class="btn btn-outline btn-accent">
              .btn-outline.btn-accent
            </div>
            <div class="btn btn-outline btn-neutral">
              .btn-outline.btn-accent
            </div>
            <div class="toast toast-info">
              <div
                data-scope="toast"
                data-part="root"
                data-type="info"
                class="my-4 max-w-64 p-4"
              >
                .toast info
              </div>
            </div>
            <div class="alert alert-primary my-4 max-w-64 p-4">
              .alert.alert-primary
            </div>

            <div class="alert alert-error my-4 max-w-64 p-4">
              .alert.alert-error
            </div>

            {["bg-base-100", "bg-base-200", "bg-base-300"].map((bg) => {
              return (
                <div class={`m-2 rounded p-2 ${bg} inline-block h-20 w-50`}>
                  <h2 class="text-xl">.{bg}</h2>
                </div>
              );
            })}
          </div>
        );
      },
    )
  }
</Layout>
