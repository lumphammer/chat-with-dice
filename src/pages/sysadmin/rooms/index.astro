---
import { auth } from "#/auth";
import { db } from "#/db";
import SysAdminLayout from "#/layouts/SysAdmin.astro";
import { rooms } from "#/schemas/coreD1-schema";
import { AdminRoomList } from "@/components/sysAdmin/rooms/AdminRoomList";
import { desc } from "drizzle-orm";

export const prerender = false;

const MAX_ROOMS = 500;

const allRooms = await db
  .select()
  .from(rooms)
  .orderBy(desc(rooms.createdTime))
  .limit(MAX_ROOMS);

// Fetch creator info for all rooms
type CreatorInfo = { id: string; name: string | null; email: string };
const userMap: Record<string, CreatorInfo> = {};
try {
  const result = await auth.api.listUsers({
    query: { limit: 1000 },
    headers: Astro.request.headers,
  });
  for (const user of result.users) {
    userMap[user.id] = { id: user.id, name: user.name, email: user.email };
  }
} catch {
  //
}

const adminRooms = allRooms.map((room) => ({
  ...room,
  creatorName: userMap[room.createdByUserId]?.name ?? null,
  creatorEmail: userMap[room.createdByUserId]?.email ?? null,
}));
---

<SysAdminLayout title={"Rooms 🎲"} class="flex flex-col">
  <div class="flex-1">
    <AdminRoomList rooms={adminRooms} client:load />
  </div>
</SysAdminLayout>
