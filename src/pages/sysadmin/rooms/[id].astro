---
import { auth } from "#/auth";
import { db } from "#/db";
import SysAdminLayout from "#/layouts/SysAdmin.astro";
import { rooms } from "#/schemas/chatDB-schema";
import { eq } from "drizzle-orm";
import { RoomDetailPage } from "./_components/RoomDetailPage";

export const prerender = false;

const { id } = Astro.params;

const [room] = await db
  .select()
  .from(rooms)
  .where(eq(rooms.id, id!))
  .limit(1);

if (!room) return Astro.redirect("/sysadmin/rooms/");

type CreatorInfo = { id: string; name: string | null; email: string };
let creator: CreatorInfo | null = null;
try {
  const result = await auth.api.getUser({
    query: { userId: room.created_by_user_id },
    headers: Astro.request.headers,
  });
  if (result?.user) {
    creator = {
      id: result.user.id,
      name: result.user.name,
      email: result.user.email,
    };
  }
} catch {
  //
}
---

<SysAdminLayout title={room.name}>
  <div class="p-4">
    <RoomDetailPage room={room} creator={creator} client:load />
  </div>
</SysAdminLayout>
