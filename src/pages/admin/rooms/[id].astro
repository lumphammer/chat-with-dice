---
import { auth } from "#/auth/auth";
import { db } from "#/db";
import AdminLayout from "#/layouts/Admin.astro";
import { rooms } from "#/schemas/coreD1-schema";
import { RoomDetailPage } from "@/components/admin/rooms/RoomDetailPage";
import type { User } from "better-auth/types";
import { eq } from "drizzle-orm";

export const prerender = false;

const { id } = Astro.params;

const [room] = await db.select().from(rooms).where(eq(rooms.id, id!)).limit(1);

if (!room) return Astro.redirect("/admin/rooms/");

let creator: User | null = null;
try {
  creator = await auth.api.getUser({
    query: { id: room.createdByUserId },
    headers: Astro.request.headers,
  });
} catch {
  //
}
---

<AdminLayout title={room.name}>
  <div class="p-4">
    <RoomDetailPage room={room} creator={creator} client:load />
  </div>
</AdminLayout>
