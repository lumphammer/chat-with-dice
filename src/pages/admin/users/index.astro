---
import { auth } from "#/auth/auth";
import AdminLayout from "#/layouts/Admin.astro";
import { AdminUserList } from "@/components/admin/users/AdminUserList";
import type { UserWithRole } from "better-auth/plugins";

export const prerender = false;

let users: UserWithRole[] = [];
let total = 0;

try {
  const result = await auth.api.listUsers({
    query: {},
    headers: Astro.request.headers,
  });
  users = result.users;
  total = result.total;
} catch {
  //
}
---

<AdminLayout title={"Users 🕵️‍♀️"} class="flex flex-col">
  {
    (
      <div class="flex-1">
        <AdminUserList users={users} total={total} client:load />
      </div>
    )
  }
</AdminLayout>
