---
import { toClientUser } from "#/auth/clientUser.ts";
import Layout from "#/layouts/Layout.astro";
import { AccountSettingsForm } from "./_components/AccountSettingsForm";

export const prerender = false;

if (!Astro.locals.user) {
  return Astro.redirect("/signin");
}
---

<Layout title="Account Settings" class="flex justify-center p-8">
  <AccountSettingsForm
    client:load
    initialUser={toClientUser(Astro.locals.user)}
  />
</Layout>
