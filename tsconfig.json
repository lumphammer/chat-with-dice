{
  "extends": "astro/tsconfigs/strict",
  "module": "esnext",
  "include": [".astro/types.d.ts", "**/*"],
  "exclude": ["dist"],
  "lib": ["dom", "esnext"],
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "strict": true,
    "paths": {
      "#/*": ["./src/*"],
      "@/*": ["./src/*"]
    }
  }
}
