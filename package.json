{
  "type": "module",
  "name": "@lumphammer/chat-with-dice",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "pnpm run build && astro preview",
    "test": "vitest",
    "astro": "astro",
    "types:check": "astro check",
    "deploy": "pnpm run build && wrangler deploy",
    "format:check": "prettier --check .",
    "format:fix": "prettier --write .",
    "lint:check": "oxlint --type-aware",
    "lint:fix": "oxlint --fix --type-aware --fix-dangerously --fix-suggestions",
    "check": "pnpm run types:check && pnpm run lint:check && pnpm run format:check && pnpm run build",
    "types:generate:cloudflare": "wrangler types src/worker-configuration.d.ts",
    "db:generateauthschema": "npx https://pkg.pr.new/better-auth/better-auth/auth@9489 generate --output=src/schemas/auth-schema.ts",
    "db:generate:coreD1": " DATABASE_BINDING=CORE_D1 drizzle-kit generate",
    "db:generate:roller": "drizzle-kit generate --config=./drizzle.config.roller.ts",
    "db:migrate:coreD1:local": "DATABASE_BINDING=CORE_D1 LOCAL=yes drizzle-kit migrate",
    "db:migrate:coreD1:prod": "DATABASE_BINDING=CORE_D1 drizzle-kit migrate",
    "db:migrate:coreD1:staging": "DATABASE_BINDING=CORE_D1 ENV=staging  drizzle-kit migrate",
    "db:studio:coreD1:local": "DATABASE_BINDING=CORE_D1 LOCAL=yes drizzle-kit studio",
    "db:studio:coreD1:prod": "DATABASE_BINDING=CORE_D1 drizzle-kit studio",
    "db:studio:coreD1:staging": "DATABASE_BINDING=CORE_D1 ENV=staging drizzle-kit studio"
  },
  "dependencies": {
    "@ark-ui/react": "^5.36.2",
    "@astrojs/check": "0.9.9",
    "@astrojs/cloudflare": "13.3.0",
    "@astrojs/react": "5.0.4",
    "@better-auth/drizzle-adapter": "https://pkg.pr.new/@better-auth/drizzle-adapter@9489",
    "@dice-roller/rpg-dice-roller": "^5.5.1",
    "@fontsource-variable/orbitron": "^5.2.8",
    "@lucide/astro": "^1.14.0",
    "@nanostores/react": "^1.1.0",
    "@svgr/core": "^8.1.0",
    "@svgr/plugin-jsx": "^8.1.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.4",
    "@tanstack/react-query": "^5.100.6",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "astro": "6.2.1",
    "better-auth": "https://pkg.pr.new/better-auth@9489",
    "better-sqlite3": "^12.9.0",
    "daisyui": "^5.5.19",
    "dotenv": "^17.4.2",
    "drizzle-kit": "1.0.0-beta.22",
    "drizzle-orm": "1.0.0-beta.22",
    "immer": "^11.1.4",
    "lucide-react": "^0.575.0",
    "nanoid": "^5.1.9",
    "nanostores": "^1.3.0",
    "oxlint": "^1.62.0",
    "oxlint-tsgolint": "^0.15.0",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-astro-organize-imports": "^0.4.12",
    "prettier-plugin-classnames": "^0.9.0",
    "prettier-plugin-merge": "^0.10.1",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-tailwindcss": "^0.7.4",
    "quikdown": "^1.2.12",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "reconnecting-websocket": "^4.4.0",
    "rollup-plugin-visualizer": "^7.0.1",
    "svgo": "^4.0.1",
    "tailwindcss": "^4.2.4",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5",
    "wrangler": "^4.87.0",
    "zod": "^4.4.1"
  },
  "peerDependencies": {
    "vite": "<8.0.0"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319"
}
