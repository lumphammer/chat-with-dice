{
  "type": "module",
  "name": "@lumphammer/chat-with-dice",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "pnpm run build && astro preview",
    "test": "vitest --typecheck",
    "test:once": "pnpm test --run",
    "astro": "astro",
    "types:check": "astro check",
    "deploy": "pnpm run build && wrangler deploy",
    "format:check": "prettier --check .",
    "format:fix": "prettier --write .",
    "lint:check": "oxlint --type-aware",
    "lint:fix": "oxlint --fix --type-aware --fix-dangerously --fix-suggestions",
    "knip": "DATABASE_BINDING=CORE_D1 knip --production",
    "check": "pnpm run types:check && pnpm run lint:check && pnpm run format:check && pnpm run test:once && pnpm run build",
    "types:generate:cloudflare": "wrangler types src/worker-configuration.d.ts",
    "db:generate:authSchema": "npx https://pkg.pr.new/better-auth/better-auth/auth@9489 generate --output=src/schemas/auth-schema.ts",
    "db:generate:coreD1": " DATABASE_BINDING=CORE_D1 drizzle-kit generate",
    "db:generate:ChatRoomDO": "DO_BINDING=CHAT_ROOM_DO drizzle-kit generate --config=./drizzle.durableObjects.config.ts",
    "db:generate:UserDataDO": "DO_BINDING=USER_DATA_DO drizzle-kit generate --config=./drizzle.durableObjects.config.ts",
    "db:migrate:coreD1:local": "DATABASE_BINDING=CORE_D1 LOCAL=yes drizzle-kit migrate",
    "db:migrate:coreD1:prod": "DATABASE_BINDING=CORE_D1 drizzle-kit migrate",
    "db:migrate:coreD1:staging": "DATABASE_BINDING=CORE_D1 ENV=staging  drizzle-kit migrate",
    "db:studio:coreD1:local": "DATABASE_BINDING=CORE_D1 LOCAL=yes drizzle-kit studio",
    "db:studio:coreD1:prod": "DATABASE_BINDING=CORE_D1 drizzle-kit studio",
    "db:studio:coreD1:staging": "DATABASE_BINDING=CORE_D1 ENV=staging drizzle-kit studio"
  },
  "dependencies": {
    "@ark-ui/react": "^5.37.2",
    "@astrojs/check": "0.9.9",
    "@astrojs/cloudflare": "14.1.1",
    "@astrojs/compiler-rs": "^0.3.0",
    "@astrojs/react": "6.0.1",
    "@better-auth/drizzle-adapter": "^1.6.23",
    "@cloudflare/vitest-pool-workers": "^0.16.20",
    "@fontsource-variable/orbitron": "^5.2.8",
    "@lucide/astro": "^1.23.0",
    "@nanostores/react": "^1.1.0",
    "@svgr/core": "^8.1.0",
    "@svgr/plugin-jsx": "^8.1.0",
    "@tailwindcss/typography": "^0.5.20",
    "@tailwindcss/vite": "^4.3.2",
    "@tanstack/react-query": "^5.101.2",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@use-gesture/react": "^10.3.1",
    "astro": "7.0.6",
    "better-auth": "^1.6.23",
    "better-sqlite3": "^12.11.1",
    "daisyui": "^5.6.13",
    "dotenv": "^17.4.2",
    "drizzle-kit": "1.0.0-rc.2",
    "drizzle-orm": "1.0.0-rc.2",
    "immer": "^11.1.9",
    "lucide-react": "^1.23.0",
    "nanoid": "^5.1.16",
    "nanostores": "^1.4.0",
    "oxlint": "^1.72.0",
    "oxlint-tsgolint": "^0.22.1",
    "prettier": "^3.9.4",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-astro-organize-imports": "^0.4.12",
    "prettier-plugin-classnames": "^0.10.3",
    "prettier-plugin-merge": "^0.10.1",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "quikdown": "^1.2.21",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.80.0",
    "reconnecting-websocket": "^4.4.0",
    "rollup-plugin-visualizer": "^7.0.1",
    "svgo": "^4.0.1",
    "tailwindcss": "^4.3.2",
    "vitest": "^4.1.9",
    "wrangler": "^4.107.0",
    "zod": "^4.4.3"
  },
  "peerDependencies": {
    "vite": "^8.0.0"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "12.0.0-alpha.10",
      "onFail": "download"
    }
  },
  "devDependencies": {
    "@types/node": "^25.9.4",
    "knip": "^6.24.0",
    "typescript": "^6.0.3"
  }
}
