{
  "type": "module",
  "name": "@lumphammer/chat-with-dice",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "pnpm run build && astro preview",
    "astro": "astro",
    "types:check": "astro check",
    "deploy": "pnpm run build && wrangler deploy",
    "format:check": "prettier --check .",
    "format:fix": "prettier --write .",
    "lint:check": "oxlint --type-aware",
    "lint:fix": "oxlint --fix --type-aware --fix-dangerously --fix-suggestions",
    "cloudflare-types": "wrangler types src/worker-configuration.d.ts",
    "db:generateauthschema": "npx https://pkg.pr.new/better-auth/better-auth/@better-auth/cli@6913 generate --output=src/schemas/auth-schema.ts",
    "db:generate:todos": " DATABASE_BINDING=todos drizzle-kit generate",
    "db:generate:chatdb": " DATABASE_BINDING=chatDB drizzle-kit generate",
    "db:generate:roller": "drizzle-kit generate --config=./drizzle.config.roller.ts",
    "db:migrate:todos:local": "DATABASE_BINDING=todos LOCAL=yes drizzle-kit migrate",
    "db:migrate:todos:prod": "DATABASE_BINDING=todos drizzle-kit migrate",
    "db:migrate:todos:staging": "DATABASE_BINDING=todos ENV=staging drizzle-kit migrate",
    "db:migrate:chatdb:local": "DATABASE_BINDING=chatDB LOCAL=yes drizzle-kit migrate",
    "db:migrate:chatdb:prod": "DATABASE_BINDING=chatDB drizzle-kit migrate",
    "db:migrate:chatdb:staging": "DATABASE_BINDING=chatDB ENV=staging  drizzle-kit migrate",
    "db:studio:todos:local": "DATABASE_BINDING=todos LOCAL=yes drizzle-kit studio",
    "db:studio:todos:prod": "DATABASE_BINDING=todos drizzle-kit studio",
    "db:studio:todos:staging": "DATABASE_BINDING=todos ENV=staging drizzle-kit studio",
    "db:studio:chatdb:local": "DATABASE_BINDING=chatDB LOCAL=yes drizzle-kit studio",
    "db:studio:chatdb:prod": "DATABASE_BINDING=chatDB drizzle-kit studio",
    "db:studio:chatdb:staging": "DATABASE_BINDING=chatDB ENV=staging drizzle-kit studio"
  },
  "dependencies": {
    "@ark-ui/react": "^5.34.1",
    "@astrojs/check": "0.9.7",
    "@astrojs/cloudflare": "13.1.1",
    "@astrojs/react": "5.0.0",
    "@better-auth/drizzle-adapter": "https://pkg.pr.new/better-auth/better-auth/@better-auth/drizzle-adapter@6913",
    "@dice-roller/rpg-dice-roller": "^5.5.1",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/react-query": "^5.90.21",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "astro": "6.0.4",
    "better-auth": "^1.5.5",
    "better-sqlite3": "^12.8.0",
    "daisyui": "^5.5.19",
    "dotenv": "^17.3.1",
    "drizzle-kit": "1.0.0-beta.15-859cf75",
    "drizzle-orm": "1.0.0-beta.15-859cf75",
    "immer": "^11.1.4",
    "lucide-react": "^0.575.0",
    "nanoid": "^5.1.6",
    "oxlint": "^1.55.0",
    "oxlint-tsgolint": "^0.15.0",
    "prettier": "^3.8.1",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-astro-organize-imports": "^0.4.11",
    "prettier-plugin-classnames": "^0.9.0",
    "prettier-plugin-merge": "^0.10.0",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "quikdown": "^1.1.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "rollup-plugin-visualizer": "^7.0.1",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "wrangler": "^4.73.0",
    "zod": "^4.3.6"
  }
}
